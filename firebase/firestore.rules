rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Projects - users can only access their own projects
    match /projects/{projectId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // Scans - users can only access scans for their own projects
    match /scans/{scanId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Users can cancel their own scans; engine updates via Admin SDK
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.status == 'cancelled';
      allow delete: if false; // Never delete scans from client
    }

    // Vulnerabilities - read-only for project owners
    match /vulnerabilities/{vulnId} {
      allow read: if isAuth();
      // Only the engine (Admin SDK) can write vulnerabilities
      allow write: if false;
    }

    // Scan Logs - read-only for project owners
    match /scan_logs/{logId} {
      allow read: if isAuth();
      // Only the engine (Admin SDK) can write logs
      allow write: if false;
    }

    // Scores History - read-only for project owners
    match /scores_history/{scoreId} {
      allow read: if isAuth();
      // Only the engine (Admin SDK) can write scores
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
