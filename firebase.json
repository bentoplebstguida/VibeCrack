{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "hosting": {
    "public": "frontend/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": true,
    "rewrites": [
      {
        "source": "/scans/**",
        "destination": "/scans/detail/index.html"
      },
      {
        "source": "/projects/**",
        "destination": "/projects/index.html"
      },
      {
        "source": "/reports/**",
        "destination": "/reports/index.html"
      },
      {
        "source": "/dashboard/**",
        "destination": "/dashboard/index.html"
      },
      {
        "source": "/settings/**",
        "destination": "/settings/index.html"
      }
    ]
  }
}